{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yt-dlp Desktop",
  "mainBinaryName": "yt-dlp-desktop",
  "version": "0.1.0",
  "identifier": "io.github.nitrodiesel.ytdlpdesktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "yt-dlp Desktop",
        "width": 1180,
        "height": 780,
        "minWidth": 720,
        "minHeight": 580,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/yt-dlp", "binaries/deno"],
    "resources": [
      "resources/THIRD_PARTY_NOTICES.txt",
      "resources/DENO_LICENSE.md",
      "resources/YT_DLP_THIRD_PARTY_LICENSES.txt"
    ],
    "copyright": "Copyright (c) 2026 yt-dlp Desktop contributors",
    "category": "Utility",
    "shortDescription": "Download media with yt-dlp",
    "longDescription": "A task-focused, cross-platform desktop interface for yt-dlp.",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
